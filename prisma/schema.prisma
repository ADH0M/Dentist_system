generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
}

// ==========================================
// 👤 Users & Authentication
// ==========================================
model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  username       String
  email          String?   @unique
  phone          String    @unique
  password       String
  role           UserType  @default(assistant)
  birthDate      DateTime?
  gender         Gender?
  address        String?
  profile_avatar String?
  isActive       Boolean   @default(true)
  isOnline       Boolean   @default(false)
  isVerified     Boolean   @default(false)

  patient      Patient?
  // Relations - Tasks & Appointments
  appointments Appointment[]
  tasks        Task[]
  activityLogs ActivityLog[]
  invoices     Invoice[]

  // 🔁 Opposite Relations for Audit Fields (إصلاح خطأ العلاقات الناقصة)
  createdPatients Patient[]        @relation("PatientCreatedBy")
  createdVisits   Visit[]          @relation("VisitCreatedBy")
  uploadedImages  RadiologyImage[] @relation("ImageUploadedBy")
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([deletedAt])
}

// ==========================================
// 🏥 Patients (Medical Records)
// ==========================================
model Patient {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade) // 1-to-1 with User

  // 📋 Medical History Summary
  allergies   String[]
  medications String[]
  notes       String?

  // Relations
  visits       Visit[]
  images       RadiologyImage[]
  invoices     Invoice[]
  appointments Appointment[]

  // 👮 Audit: مين سجل المريض ده؟
  createdById String?   @db.ObjectId
  createdBy   User?     @relation("PatientCreatedBy", fields: [createdById], references: [id])
  lastVisitAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([createdById])
}

// ==========================================
// 📅 Appointments (Scheduling)
// ==========================================
model Appointment {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(scheduled)
  notes     String?

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId String @db.ObjectId
  doctor   User   @relation(fields: [doctorId], references: [id])

  // 🔗 ربط مع الزيارة (1-to-1) -> لازم @unique
  visitId String? @unique @db.ObjectId
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([doctorId, startTime])
  @@index([patientId])
  @@index([status])
}

// ==========================================
// 🦷 Visits (Clinical Data - Per Visit)
// ==========================================
model Visit {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  visitDate      DateTime  @default(now())
  type           VisitType @default(Initial)
  chiefComplaint String?

  diagnosis      String?
  treatmentPlan  String?
  proceduresDone String?

  // 🦷 Tooth Charting Example:
  // { "11": { "status": "caries", "surfaces": ["M", "O"] }, "16": "missing" }
  toothChart Json?

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // 🔗 علاقات مع الفاتورة والميعاد
  invoice     Invoice?
  appointment Appointment?

  // 👮 Audit
  createdById String? @db.ObjectId
  createdBy   User?   @relation("VisitCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // 🗑️ Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([visitDate])
  @@index([createdById])
  @@index([patientId, visitDate])
}

// ==========================================
// 💰 Billing & Invoices
// ==========================================
model Invoice {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String?        @unique
  totalAmount   Float
  paidAmount    Float          @default(0)
  status        PaymentStatus  @default(pending)
  paymentMethod PaymentMethod?
  notes         String?
  dueDate       DateTime?

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  // 🔗 ربط مع الزيارة (1-to-1) -> لازم @unique
  visitId String? @unique @db.ObjectId
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  createdById String @db.ObjectId
  createdBy   User   @relation(fields: [createdById], references: [id])

  // 🗑️ Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([patientId, status]) // ADDED
}

// ==========================================
// 📋 Internal Tasks
// ==========================================
model Task {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  title    String
  content  String?
  isDone   Boolean   @default(false)
  priority Int       @default(1)
  dueDate  DateTime?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isDone])
}

// ==========================================
// 🖼️ Radiology & Images
// ==========================================
model RadiologyImage {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  url         String
  type        String?
  description String?
  toothNumber String?

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // 👮 Audit: مين رفع الصورة؟
  uploadedById String? @db.ObjectId
  uploadedBy   User?   @relation("ImageUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  // 🗑️ Soft Delete
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([patientId])
}

// ==========================================
// 📊 Activity Logs (Audit Trail)
// ==========================================
model ActivityLog {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  action     String
  entityType String?
  entityId   String? @db.ObjectId
  details    Json?
  ipAddress  String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

// ==========================================
// 📦 Enums
// ==========================================
enum UserType {
  admin
  dentist
  assistant
  receptionist
  patient
}

enum Gender {
  male
  female
}

enum VisitType {
  Initial
  FollowUp
  Emergency
  Cleaning
  Consultation
  Surgery
}

enum AppointmentStatus {
  scheduled
  confirmed
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum PaymentStatus {
  pending
  paid
  partially_paid
  refunded
  cancelled
  insurance_pending
}

enum PaymentMethod {
  Cash
  Card
  Online
  Insurance
  Installment
}
